{
    "interface_version": 2,
    "name": "MaaWXCard",
    "description": "这是一个使用 MaaFramework 创建的微信小程序打卡工具。",
    "welcome": "首次使用！欢迎使用 MAA!",
    "github": "https://github.com/cewly/MaaWXcard",
    "version": "v1.0.0",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720
        },
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "群打卡",
                "screencap": "ScreenDC",
                "mouse": "PostMessageWithCursorPos",
                "keyboard": "PostMessageWithCursorPos"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        },
        {
            "name": "B 服",
            "path": [
                "./resource",
                "./resource_bilibili"
            ]
        }
    ],
    "task": [
        {
            "name": "签到",
            "entry": "签到begin"
        },
        {
            "name": "签退",
            "entry": "签退begin"
        }
    ],
    "option": {
        "任务选项1": {
            "type": "select",
            "cases": [
                {
                    "name": "文本1",
                    "pipeline_override": {
                        "OcrTask": {
                            "text": "文本1"
                        }
                    }
                },
                {
                    "name": "文本2",
                    "pipeline_override": {
                        "OcrTask": {
                            "text": "文本2"
                        }
                    }
                }
            ]
        }
    }
}